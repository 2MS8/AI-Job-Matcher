{
  "manifest_version": 3,
  "name": "Job Matcher",
  "version": "1.2.0",
  "description": "Analyze how well your resume matches job descriptions on LinkedIn, Indeed, and Naukri using NLP.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.naukri.com/*"
      ],
      "js": [
        "content/contentScript.js"
      ],
      "css": [
        "content/injector.css"
      ]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar/sidebar.html",
        "sidebar/*",
        "shared/*",
        "623/*",
        "content/injector.css",
        "icons/*",
        "lib/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}